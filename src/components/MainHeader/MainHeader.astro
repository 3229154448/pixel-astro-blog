---
import { siteConfig } from '@/config';
import { withBase } from '@/utils/path';
const typewriterTexts = JSON.stringify(siteConfig.typewriter);
---
<div class="home-banner">
  <div class="banner-decorations">
    <div class="deco-block d1"></div><div class="deco-block d2"></div>
    <div class="deco-block d3"></div><div class="deco-block d4"></div>
    <div class="deco-block d5"></div>
  </div>
  <div class="banner-inner">
    <div class="avatar-wrap">
      <img src={withBase('/assets/images/avatar-default.webp')} alt={siteConfig.author} class="banner-avatar" width="128" height="128" />
      <div class="avatar-badge">🎮</div>
    </div>
    <h1 class="banner-title pixel-font">PIXEL DEVELOPER</h1>
    <p class="banner-subtitle" id="main-typewriter"></p>
    <div class="banner-actions">
      <a href={withBase('/archives')} class="pixel-btn accent">🚀 开始探索</a>
      <a href="https://github.com" target="_blank" class="pixel-btn yellow">🐱 GitHub</a>
    </div>
  </div>
  <div class="banner-bottom-line"></div>
</div>

<style lang="less">
.home-banner {
  position: relative; background: var(--pixel-secondary);
  border-bottom: 4px solid var(--pixel-dark); overflow: hidden;
}
.banner-decorations { position: absolute; inset: 0; pointer-events: none;
  &::before {
    content: ''; position: absolute; inset: 0; opacity: 0.1;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--pixel-dark) 2px, var(--pixel-dark) 4px);
  }
}
.deco-block {
  position: absolute; border: 2px solid var(--pixel-dark); animation: float 4s ease-in-out infinite;
  &.d1 { top: 12%; left: 10%; width: 24px; height: 24px; background: var(--pixel-yellow); border-width: 3px; animation-delay: 0s; }
  &.d2 { top: 20%; right: 15%; width: 16px; height: 16px; background: var(--pixel-accent); animation-delay: 1s; }
  &.d3 { bottom: 25%; left: 20%; width: 20px; height: 20px; background: var(--pixel-purple); animation-delay: 2s; }
  &.d4 { top: 30%; left: 60%; width: 12px; height: 12px; background: white; animation-delay: 0.5s; }
  &.d5 { bottom: 40%; right: 25%; width: 28px; height: 28px; background: var(--pixel-cyan); border-width: 3px; animation-delay: 1.5s; }
}
@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  33% { transform: translateY(-10px) rotate(2deg); }
  66% { transform: translateY(-5px) rotate(-2deg); }
}
.banner-inner {
  position: relative; z-index: 1; max-width: var(--vh-main-max-width);
  margin: 0 auto; padding: 4rem 2rem; text-align: center;
}
.avatar-wrap { position: relative; display: inline-block; margin-bottom: 1.5rem; }
.banner-avatar {
  width: 128px; height: 128px; border: 4px solid var(--pixel-dark);
  box-shadow: 6px 6px 0 0 var(--pixel-dark); image-rendering: pixelated; background: white;
}
.avatar-badge {
  position: absolute; bottom: -4px; right: -4px;
  width: 32px; height: 32px; background: var(--pixel-accent);
  border: 3px solid var(--pixel-dark); display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}
.banner-title {
  font-size: 20px; color: white; margin-bottom: 1rem;
  text-shadow: 4px 4px 0 var(--pixel-dark);
}
.banner-subtitle {
  font-family: var(--pixel-font-body); font-size: 22px; color: rgba(255,255,255,0.95);
  min-height: 30px; margin-bottom: 2rem; font-weight: bold;
  &::after { content: '▋'; animation: blink 1s infinite; color: var(--pixel-accent); font-weight: bold; margin-left: 2px; }
}
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
.banner-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
.pixel-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 20px; font-family: var(--pixel-font-body); font-size: 16px; font-weight: bold;
  color: white; border: 4px solid var(--pixel-dark); box-shadow: 6px 6px 0 0 var(--pixel-dark);
  cursor: pointer; transition: all 0.1s; text-decoration: none;
  &:hover { transform: translate(-1px, -1px); box-shadow: 7px 7px 0 0 var(--pixel-dark); }
  &:active { transform: translate(4px, 4px); box-shadow: 0 0 0 0 var(--pixel-dark); }
  &.accent { background: var(--pixel-accent); }
  &.yellow { background: var(--pixel-yellow); color: var(--pixel-dark); }
}
.banner-bottom-line { position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background: var(--pixel-dark); }
@media (max-width: 768px) {
  .banner-inner { padding: 2.5rem 1rem; }
  .banner-title { font-size: 14px; }
  .banner-subtitle { font-size: 18px; }
  .banner-avatar { width: 96px; height: 96px; }
}
</style>

<script is:inline define:vars={{ typewriterTexts }}>
  const texts = JSON.parse(typewriterTexts); const el = document.getElementById('main-typewriter');
  if (el) { let ti=0,ci=0,d=false; function t(){const c=texts[ti];if(d){el.textContent=c.substring(0,--ci);}else{el.textContent=c.substring(0,++ci);}let dl=d?50:120;if(!d&&ci===c.length){dl=2000;d=true;}else if(d&&ci===0){d=false;ti=(ti+1)%texts.length;dl=500;}setTimeout(t,dl);}t(); }
</script>
