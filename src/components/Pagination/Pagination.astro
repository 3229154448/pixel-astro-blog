---
interface Props { currentPage: number; totalPages: number; baseUrl?: string; }
const { currentPage, totalPages, baseUrl = '' } = Astro.props;
---
{totalPages > 1 && (
  <nav class="pagination">
    <button class="pixel-btn page-btn" disabled={currentPage <= 1}>◁</button>
    {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
      <button class:list={['pixel-btn', 'page-btn', { active: page === currentPage }]}>
        {page}
      </button>
    ))}
    <button class="pixel-btn page-btn" disabled={currentPage >= totalPages}>▷</button>
  </nav>
)}

<style lang="less">
.pagination { display: flex; justify-content: center; gap: 4px; margin: 2.5rem 0; flex-wrap: wrap; }
.page-btn {
  padding: 8px 14px; background: var(--pixel-bg-grid); color: var(--pixel-dark);
  font-family: var(--pixel-font-title); font-size: 10px;
  border: 3px solid var(--pixel-dark); box-shadow: 3px 3px 0 0 var(--pixel-dark);
  &:hover:not(:disabled) { transform: translate(-1px, -1px); box-shadow: 4px 4px 0 0 var(--pixel-dark); }
  &:active:not(:disabled) { transform: translate(3px, 3px); box-shadow: 0 0 0 0 var(--pixel-dark); }
  &.active { background: var(--pixel-accent); color: white; }
  &:disabled { opacity: 0.4; cursor: not-allowed; }
}
</style>
