<button class="back-top" id="back-top" title="返回顶部">▲ TOP</button>

<style lang="less">
.back-top {
  position: fixed; bottom: 2rem; right: 2rem; z-index: 90;
  padding: 10px 16px; font-family: var(--pixel-font-title); font-size: 9px;
  color: white; background: var(--pixel-accent); border: 4px solid var(--pixel-dark);
  box-shadow: 4px 4px 0 0 var(--pixel-dark); cursor: pointer;
  opacity: 0; transform: translateY(20px); transition: all 0.3s ease; pointer-events: none;
  &.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
  &:hover { transform: translate(-1px, -1px); box-shadow: 5px 5px 0 0 var(--pixel-dark); }
  &:active { transform: translate(3px, 3px); box-shadow: 0 0 0 0 var(--pixel-dark); }
}
</style>

<script>
  const b = document.getElementById('back-top');
  if (b) { window.addEventListener('scroll', () => { b.classList.toggle('visible', window.scrollY > 300); }); b.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); }); }
</script>
