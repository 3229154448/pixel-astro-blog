---
import { siteConfig } from '@/config';
---
<footer class="vh-footer">
  <div class="footer-inner">
    <div class="footer-pixel">◼</div>
    <p class="footer-text">© {new Date().getFullYear()} {siteConfig.author} | Powered by <a href="https://astro.build" target="_blank">Astro</a></p>
    <p class="footer-sub">PIXEL.BLOG ◼ {siteConfig.motto}</p>
  </div>
</footer>

<style lang="less">
.vh-footer { background: var(--pixel-bg-grid); border-top: 4px solid var(--pixel-dark); margin-top: auto; }
.footer-inner { max-width: var(--vh-main-max-width); margin: 0 auto; padding: 2rem; text-align: center; }
.footer-pixel { font-size: 24px; color: var(--pixel-accent); margin-bottom: 0.5rem; }
.footer-text { font-family: var(--pixel-font-title); font-size: 9px; color: var(--pixel-text-dim); a { color: var(--pixel-accent); } }
.footer-sub { font-family: var(--pixel-font-body); font-size: 16px; color: var(--pixel-text-dim); margin-top: 0.5rem; }
</style>
