---
import Layout from '@/layouts/Layout/Layout.astro';
---
<Layout title="404 - 页面不存在">
  <div class="not-found">
    <div class="not-found-inner pixel-card">
      <div class="pixel-404"><span>4</span><span class="glitch">0</span><span>4</span></div>
      <p class="not-found-text pixel-font">PAGE NOT FOUND!</p>
      <p class="not-found-sub">你迷路了，冒险者... 此路径不存在。</p>
      <a href="/" class="pixel-btn accent">◄ 返回首页</a>
    </div>
  </div>
</Layout>

<style lang="less">
.not-found { display: flex; justify-content: center; align-items: center; min-height: 50vh; }
.not-found-inner { text-align: center; padding: 3rem 2rem; }
.pixel-404 { font-family: var(--pixel-font-title); font-size: 48px; color: var(--pixel-accent); text-shadow: 6px 6px 0 var(--pixel-dark); margin-bottom: 1.5rem;
  span { display: inline-block; animation: float 2s ease-in-out infinite;
    &:nth-child(1) { animation-delay: 0s; }
    &:nth-child(2) { animation-delay: 0.2s; color: var(--pixel-yellow); }
    &:nth-child(3) { animation-delay: 0.4s; }
  }
  .glitch { animation: glitch 3s infinite; }
}
.pixel-font { font-family: var(--pixel-font-title); }
.not-found-text { font-size: 12px; color: var(--pixel-accent); margin-bottom: 0.5rem; }
.not-found-sub { font-family: var(--pixel-font-body); font-size: 20px; color: var(--pixel-text-dim); margin-bottom: 2rem; }
.pixel-btn { display: inline-block; padding: 10px 20px; font-family: var(--pixel-font-body); font-size: 16px; font-weight: bold; color: white; background: var(--pixel-accent); border: 4px solid var(--pixel-dark); box-shadow: 6px 6px 0 0 var(--pixel-dark); cursor: pointer; text-decoration: none;
  &:hover { transform: translate(-1px, -1px); box-shadow: 7px 7px 0 0 var(--pixel-dark); }
  &:active { transform: translate(4px, 4px); box-shadow: 0 0 0 0 var(--pixel-dark); }
}
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
@keyframes glitch { 0%, 90%, 100% { transform: translate(0); } 92% { transform: translate(-4px, 2px); color: var(--pixel-blue); } 94% { transform: translate(4px, -2px); color: var(--pixel-accent); } 96% { transform: translate(-2px, 4px); } 98% { transform: translate(2px, -4px); } }
</style>
