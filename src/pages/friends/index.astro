---
import PageLayout from '@/layouts/PageLayout/PageLayout.astro';
import { withBase } from '@/utils/path';
import { friendsData } from '@/page_data/Friends';
---
<PageLayout title="圈子">
  <h1 class="pixel-page-title">🌍 圈子</h1>
  <p class="page-desc">推荐阅读 · 优质内容分享</p>
  <div class="friends-grid">
    {friendsData.map(friend => (
      <a href={friend.link} target="_blank" class="friend-card pixel-card">
        <div class="friend-avatar">
          <img src={friend.avatar.startsWith('http') ? friend.avatar : withBase(friend.avatar)} alt={friend.name} width="48" height="48" loading="lazy" />
        </div>
        <div class="friend-info">
          <span class="friend-name">{friend.name}</span>
          <span class="friend-desc">{friend.description}</span>
        </div>
      </a>
    ))}
  </div>
</PageLayout>

<style lang="less">
.pixel-page-title { font-family: var(--pixel-font-title); font-size: 16px; color: var(--pixel-dark); text-shadow: 3px 3px 0 var(--pixel-shadow-color); margin-bottom: 0.5rem; }
.page-desc { font-size: 15px; color: var(--pixel-text-dim); margin-bottom: 1.5rem; }
.friends-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
.friend-card { display: flex; align-items: center; gap: 1rem; padding: 1rem; text-decoration: none; border-bottom: none;
  &:hover { transform: translate(-2px, -2px); }
}
.friend-avatar {
  width: 48px; height: 48px; border: 3px solid var(--pixel-blue);
  box-shadow: 3px 3px 0 0 var(--pixel-dark); flex-shrink: 0; overflow: hidden;
  img { width: 100%; height: 100%; object-fit: cover; image-rendering: pixelated; }
}
.friend-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.friend-name { font-family: var(--pixel-font-title); font-size: 10px; color: var(--pixel-blue); }
.friend-desc { font-size: 15px; color: var(--pixel-text-dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>
